{
  "manifest_version": 3,
  "name": "Perplexity Automation",
  "version": "1.0.0",
  "description": "Automate Excel processing with Perplexity.ai",
  "permissions": [
    "sidePanel",
    "tabs",
    "storage",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://www.perplexity.ai/*",
    "http://localhost:3000/*",
    "ws://localhost:3000/*"
  ],
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open Automation Panel"
  },
  "content_scripts": [
    {
      "matches": ["https://www.perplexity.ai/*"],
      "js": ["src/content/index.js"]
    }
  ]
}
